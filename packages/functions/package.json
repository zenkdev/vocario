{
  "name": "functions",
  "scripts": {
    "build": "rimraf ./lib && tsgo",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "serve": "npm run build && firebase serve --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@google-cloud/text-to-speech": "6.4.1",
    "cors": "2.8.6",
    "firebase-admin": "14.0.0",
    "firebase-functions": "7.2.5",
    "mime": "4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@jest/globals": "30.4.1",
    "@types/cors": "2.8.19",
    "@types/express": "4.17.25",
    "@types/jest": "30.0.0",
    "@types/node": "22.19.21",
    "@typescript/native-preview": "7.0.0-dev.20260610.1",
    "eslint": "10.4.1",
    "firebase-functions-test": "3.5.0",
    "globals": "17.6.0",
    "jiti": "2.7.0",
    "prettier": "3.8.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "vitest": "4.1.8"
  },
  "private": true,
  "version": "0.0.1"
}
